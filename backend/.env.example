# Database Configuration
DATABASE_URL=sqlite:///./oneshot_dev.db

# Redis Configuration (for rate limiting and Celery)
REDIS_URL=redis://localhost:6379/0

# JWT Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# AWS S3 Configuration (for file storage)
S3_BUCKET=oneshot-images
S3_KEY=your-aws-access-key-id
S3_SECRET=your-aws-secret-access-key
S3_REGION=us-east-1

# GPU Provider Configuration
GPU_PROVIDER=comfy_local

# ComfyUI Local Configuration
COMFY_LOCAL_URL=http://localhost:8188

# RunPod Configuration
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id

# Output Configuration
OUTPUT_FORMAT=png
OUTPUT_QUALITY=95
MAX_INPUT_MB=20

# Security Configuration
MAX_IMAGE_DIMENSION=8192
MIN_IMAGE_DIMENSION=64

# Webhook Configuration
HMAC_SECRET=your-webhook-hmac-secret
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_RETRY_DELAYS=60,300,1800,7200

# Superwall/Payment Configuration
SUPERWALL_SECRET=your-superwall-secret-key
SUPERWALL_SIGNING_SECRET=your-superwall-signing-secret

# Entitlements Configuration
ENTITLEMENTS_DEFAULT_PLAN=free
DEV_BILLING_MODE=mock

# Fallback Limits (when no entitlements found)
FALLBACK_DAILY_JOB_LIMIT=5
FALLBACK_CONCURRENT_JOB_LIMIT=1
FALLBACK_MAX_SIDE_LIMIT=512

# Application Settings
DEFAULT_CREDITS=10
MAX_FILE_SIZE_MB=10
ENVIRONMENT=development

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Logging
LOG_LEVEL=INFO

# Monitoring & Observability
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
RELEASE_VERSION=v1.0.0

# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=8000

# Application Version
APP_VERSION=2.0.0

# Privacy & Content Safety Configuration
RETENTION_DAYS=30
NSFW_MODE=block
WATERMARK_DEFAULT=true
ENABLE_EXIF_STRIPPING=true
ENABLE_WATERMARK=true
ENABLE_NSFW_DETECTION=true
ENABLE_CONSENT_ENFORCEMENT=true

# Privacy Detection Thresholds
NSFW_CONFIDENCE_THRESHOLD=0.7
SKIN_RATIO_THRESHOLD=0.35
FLESH_TONE_THRESHOLD=0.25